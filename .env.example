# ===== PostgreSQL Configuration =====
# Copy this file to `.env.local` and fill in your real credentials.
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://neondb_owner:npg_EzLG1C6BViYl@ep-autumn-unit-atbblf6f-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ===== Auth / JWT Secret =====
# Used to sign session cookies (JWT-style HMAC token).
# Generate a strong random string, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=change-this-to-a-long-random-secret-string

# ===== Initial Admin Seed Credentials =====
# Used ONLY by the migration/seed script to create the first admin user.
# You can change username/password later from the Dashboard.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=adminpass123
SEED_ADMIN_EMAIL=mahbub.devs@gmail.com

# ===== Site URL (for tracking / analytics links) =====
NEXT_PUBLIC_SITE_URL=http://localhost:3000